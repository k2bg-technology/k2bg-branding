{
  "$schema": "https://biomejs.dev/schemas/2.3.11/schema.json",
  "extends": ["./packages/biome-config/biome.jsonc"],

  "files": {
    "includes": [
      "**/apps/**/*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc}",
