{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "**/.env.*local"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env"
      ],
      "env": [
        "NOTION_TOKEN",
        "NOTION_POST_DATABASE_ID",
        "NOTION_MEDIA_DATABASE_ID",
        "NOTION_AFFILIATE_DATABASE_ID",
        "NOTION_CONCEPT_PAGE_ID",
        "NEXT_PUBLIC_X_TIMELINE_URL",
        "INSTAGRAM_LONG_ACCESS_TOKEN",
        "FORMSPREE_FORM_ACTION_URL",
        "CLOUDINARY_CLOUD_NAME",
        "CLOUDINARY_API_KEY",
        "CLOUDINARY_API_SECRET",
        "GOOGLE_TAG_MANAGER_ID",
        "SEND_GRID_API_KEY",
        "SEND_GRID_SINGLE_SENDER_DOMAIN",
        "NEXT_PUBLIC_H_CAPTCHA_SITE_KEY",
        "H_CAPTCHA_SECRET"
      ]
    },
    "start": {},
    "lint": {},
    "format": {},
    "dev": {
      "cache": false,
      "persistent": true
    },
    "storybook": {},
    "build-storybook": {
      "outputs": [
        "storybook-static/**"
      ]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "chromatic": {
      "outputs": [
        "storybook-static"
      ],
      "env": [
        "CHROMATIC_PROJECT_TOKEN"
      ]
    },
    "generate:style": {},
    "generate:component": {}
  }
}
