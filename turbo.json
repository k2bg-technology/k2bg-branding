{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"],
      "inputs": ["$TURBO_DEFAULT$", ".env"],
      "env": [
        "NOTION_TOKEN",
        "NOTION_POST_DATABASE_ID",
        "NOTION_MEDIA_DATABASE_ID",
        "NOTION_AFFILIATE_DATABASE_ID",
        "NOTION_CONCEPT_PAGE_ID",
        "NEXT_PUBLIC_X_TIMELINE_URL",
        "INSTAGRAM_LONG_ACCESS_TOKEN",
        "NEXT_PUBLIC_FORMSPREE_FORM_ACTION_URL",
        "CLOUDINARY_CLOUD_NAME",
        "DEFAULT_OG_IMAGE_PUBLIC_ID",
        "CLOUDINARY_API_KEY",
        "CLOUDINARY_API_SECRET",
        "GOOGLE_TAG_MANAGER_ID",
        "NEXT_PUBLIC_H_CAPTCHA_SITE_KEY",
        "H_CAPTCHA_SECRET",
        "AMAZON_ACCESS_KEY_ID",
        "AMAZON_SECRET_ACCESS_KEY",
        "AMAZON_REGION",
        "AMAZON_SES_SENDER_EMAIL",
        "LOG_LEVEL",
        "COMPANY_LOGO_URL",
        "NEXT_PUBLIC_GOOGLE_ADSENSE_CLIENT_ID",
        "NEXT_PUBLIC_GOOGLE_ADSENSE_AD_SLOT_ID",
        "BLOG_SITE_BASE_URL",
        "PORTFOLIO_SITE_BASE_URL",
        "API_KEY",
        "INSTAGRAM_GRAPH_API_BASE_URL",
        "INSTAGRAM_USER_ID"
      ]
    },
    "start": {},
    "lint": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "biome.jsonc",
        "../../biome.jsonc",
        "../../packages/biome-config/biome.jsonc"
      ]
    },
    "typecheck": {},
    "format": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "biome.jsonc",
        "../../biome.jsonc",
        "../../packages/biome-config/biome.jsonc"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "storybook": {},
    "build-storybook": {
      "outputs": ["storybook-static/**/*"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "chromatic": {
      "outputs": ["storybook-static"],
      "env": ["CHROMATIC_PROJECT_TOKEN"]
    },
    "generate:style": {},
    "generate:component": {}
  }
}
