{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "**/.env.*local"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env"
      ]
    },
    "start": {},
    "lint": {},
    "format": {},
    "dev": {
      "cache": false,
      "persistent": true
    },
    "storybook": {},
    "generate:style": {}
  }
}
