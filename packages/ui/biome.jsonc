{
  "root": false,
  "extends": ["biome-config/biome.jsonc"],

  "files": {
    "includes": [
      "src/**/*.{ts,tsx}",
      "*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc}",
      ".storybook/**/*.{ts,tsx,js,mjs}"
    ]
  },

  "linter": {
    "rules": {
      "complexity": {
        // Allow forEach in non-performance-critical code.
        "noForEach": "off"
      },

      "suspicious": {
        // Storybook docs components use array index as key.
        // Recommended: avoid this in production components.
        "noArrayIndexKey": "off"
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/*.stories.tsx"],
      "linter": {
        "rules": {
          "style": { "noDefaultExport": "off" },
          "suspicious": {
            "noShadowRestrictedNames": "off"
          }
        }
      }
    },
    {
      "includes": [".storybook/**", "*.config.*", "*.d.ts"],
      "linter": {
        "rules": {
          "style": { "noDefaultExport": "off" }
        }
      }
    },
    {
      "includes": ["turbo/generators/config.ts"],
      "linter": {
        "rules": {
          "style": { "noDefaultExport": "off" }
        }
      }
    }
  ]
}
